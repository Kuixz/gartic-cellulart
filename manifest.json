{
    "manifest_version": 3,
    "name": "Gartic Cellulart for Gartic Phone",
    "version": "1.1.3",
    "description": "Level up your Gart.",
    "icons":{
        "48": "dist/icons/ico48.png",
        "128": "dist/icons/ico128.png"
    },
    "action": {
        "default_popup": "src/popup/popup.html"
    },
    "background": {
        "service_worker": "src/branches/worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["https://garticphone.com/*"],
            "js": ["dist/cellulart.js"]
        },
        {
            "matches": ["https://garticphone.com/*"],
            "js": ["dist/injector.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "host_permissions": [
        "https://garticphone.com/*"
    ],
    "permissions": [
        "storage"
    ],
    "web_accessible_resources": [
        {
            "matches": [ "https://garticphone.com/*" ],
            "resources": [ "dist/injected.js" ]
        }
    ]
}